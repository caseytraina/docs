{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Overlap Docs",
  "colors": {
    "primary": "#000000",
    "light": "#ff2700",
    "dark": "#ff2700"
  },
  "api": {
    "playground": {
      "display": "simple"
    }
